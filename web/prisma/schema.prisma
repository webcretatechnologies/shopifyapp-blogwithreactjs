generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  accountOwner        Boolean   @default(false)
  collaborator        Boolean?  @default(false)
  email               String?
  emailVerified       Boolean?  @default(false)
  firstName           String?
  lastName            String?
  locale              String?
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model Shop {
  id            Int           @id @default(autoincrement())
  domain        String        @unique
  accessToken   String        @db.Text
  planKey       String        @default("free")
  installedAt   DateTime      @default(now())
  uninstalledAt DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  appPlans      AppPlan[]
  categories    Category[]
  feedbacks     Feedback[]
  posts         Post[]
  products      Product[]
  settings      ShopSetting[]
  storeLogs     StoreLog[]
  tags          Tag[]
  webhookLogs   WebhookLog[]
}

model AppPlan {
  id           Int      @id @default(autoincrement())
  shopId       Int
  planKey      String
  articleLimit Int?
  sectionLimit Int?
  features     Json?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  shop         Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId])
}

model PlanFeature {
  id         Int     @id @default(autoincrement())
  plan       String
  featureKey String
  enabled    Boolean @default(true)
  limit      Int?

  @@unique([plan, featureKey])
  @@index([plan])
}

model ShopSetting {
  id        Int      @id @default(autoincrement())
  shopId    Int
  key       String
  value     String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  shop      Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@unique([shopId, key])
  @@index([shopId])
}

model Category {
  id        Int      @id @default(autoincrement())
  shopId    Int
  name      String
  slug      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  shop      Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  posts     Post[]

  @@unique([shopId, slug])
  @@index([shopId])
}

model Tag {
  id        Int       @id @default(autoincrement())
  shopId    Int
  name      String
  slug      String
  createdAt DateTime  @default(now())
  posts     PostTag[]
  shop      Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@unique([shopId, slug])
  @@index([shopId])
}

model Post {
  id                    Int               @id @default(autoincrement())
  shopId                Int
  categoryId            Int?
  title                 String
  slug                  String
  status                String            @default("draft")
  author                String?
  vendor                String?
  excerpt               String?           @db.Text
  featuredImage         String?           @db.Text
  contentJson           Json?
  contentHtml           String?           @db.LongText
  customCss             String?           @db.Text
  customJs              String?           @db.Text
  productSliderPosition String            @default("none")
  productSliderSource   String            @default("recommendations")
  productSliderConfig   Json?
  publishedAt           DateTime?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  canonicalUrl          String?           @db.Text
  editorMode            String            @default("wysiwyg")
  metaDescription       String?           @db.Text
  metaTitle             String?           @db.VarChar(120)
  ogDescription         String?           @db.Text
  ogImage               String?           @db.Text
  ogTitle               String?           @db.VarChar(120)
  trackingKey           String?           @unique
  category              Category?         @relation(fields: [categoryId], references: [id])
  shop                  Shop              @relation(fields: [shopId], references: [id], onDelete: Cascade)
  analytics             PostAnalytic[]
  blocks                PostBlock[]
  products              PostProduct[]
  tags                  PostTag[]
  translations          PostTranslation[]
  shopifyArticle        ShopifyArticle?

  @@index([shopId])
  @@index([shopId, status])
  @@index([shopId, categoryId])
  @@index([categoryId], map: "Post_categoryId_fkey")
}

model PostTranslation {
  id              Int      @id @default(autoincrement())
  postId          Int
  locale          String
  title           String?
  excerpt         String?  @db.Text
  contentHtml     String?  @db.LongText
  metaTitle       String?  @db.VarChar(120)
  metaDescription String?  @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  post            Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, locale])
  @@index([postId])
}

model PostBlock {
  id         Int    @id @default(autoincrement())
  postId     Int
  blockType  String
  orderIndex Int    @default(0)
  settings   Json?
  post       Post   @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
}

model PostTag {
  postId Int
  tagId  Int
  post   Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag    Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
  @@index([tagId], map: "PostTag_tagId_fkey")
}

model Product {
  id               Int           @id @default(autoincrement())
  shopId           Int
  shopifyProductId String        @unique
  title            String
  handle           String
  image            String?       @db.Text
  price            Float?
  compareAtPrice   Float?
  variantId        String?
  variantAvailable Boolean       @default(true)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  posts            PostProduct[]
  shop             Shop          @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId])
  @@index([shopifyProductId])
}

model PostProduct {
  postId    Int
  productId Int
  position  Int     @default(0)
  post      Post    @relation(fields: [postId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([postId, productId])
  @@index([postId])
  @@index([productId], map: "PostProduct_productId_fkey")
}

model ShopifyArticle {
  id                 Int       @id @default(autoincrement())
  postId             Int       @unique
  shopifyArticleId   String?
  shopifyBlogId      String?
  status             String    @default("draft")
  syncedAt           DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  // Sync tracking
  syncState          String    @default("linked") // linked | in_sync | pending_app_push | pending_shopify_pull | conflict | error | external_edit | remote_missing
  syncMode           String    @default("external_html") // external_html | managed_by_app
  lastSyncDirection  String?   // app_to_shopify | shopify_to_app
  lastSourceHash     String?   // hash of canonical app source
  lastOutboundHash   String?   // hash of exact payload pushed to Shopify (echo suppression)
  lastInboundHash    String?   // hash of last webhook payload applied
  lastRemoteUpdatedAt DateTime?
  lastError          String?   @db.Text
  structureDegraded  Boolean   @default(false)
  sourceMetafieldId  String?   // ID of the Shopify metafield storing editor source data

  // Baseline-based 2-way sync (field-level three-way merge)
  syncRevision        Int       @default(0)
  lastSyncedSnapshot  Json?     // Baseline snapshot with per-field values + hashes for 3-way merge
  conflictPayload     Json?     // Per-field conflict data when only some fields conflict

  post               Post      @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([shopifyArticleId])
}

model ArticleSyncLog {
  id               Int      @id @default(autoincrement())
  shopId           Int
  postId           Int?
  shopifyArticleId String?
  direction        String   // app_to_shopify | shopify_to_app | reconcile
  eventType        String   // create | update | delete | publish | unpublish | webhook
  status           String   // applied | skipped_echo | skipped_duplicate | conflict | error
  message          String?  @db.Text
  localHash        String?
  remoteHash       String?
  payload          Json?
  createdAt        DateTime  @default(now())

  @@index([shopId])
  @@index([postId])
  @@index([createdAt])
}

model Template {
  id          Int      @id @default(autoincrement())
  key         String   @unique
  name        String
  description String?
  thumbnail   String?
  blocks      Json
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model WebhookLog {
  id        Int      @id @default(autoincrement())
  shopId    Int
  topic     String
  payload   Json?
  status    String   @default("received")
  createdAt DateTime @default(now())
  shop      Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId])
  @@index([topic])
}

model PostAnalytic {
  id              Int      @id @default(autoincrement())
  postId          Int
  views           Int      @default(0)
  uniqueVisitors  Int      @default(0)
  addToCart       Int      @default(0)
  checkouts       Int      @default(0)
  conversions     Int      @default(0)
  revenue         Float    @default(0)
  deviceDesktop   Int      @default(0)
  deviceMobile    Int      @default(0)
  deviceTablet    Int      @default(0)
  sources         Json?
  countries       Json?
  date            DateTime @db.Date
  createdAt       DateTime @default(now())

  post            Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, date])
  @@index([postId])
}

model Feedback {
  id        Int      @id @default(autoincrement())
  shopId    Int
  rating    Int?
  topic     String?  @db.VarChar(120)
  message   String   @db.Text
  page      String?  @db.VarChar(255)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  shop      Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId])
}

model StoreLog {
  id        Int      @id @default(autoincrement())
  shopId    Int
  log       String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  shop      Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId])
}

model EmailLog {
  id              Int      @id @default(autoincrement())
  recipientEmail  String
  recipientDomain String?
  subject         String
  body            String?  @db.Text
  template        String?
  status          String   @default("sent")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model AdminActivityLog {
  id         Int      @id @default(autoincrement())
  action     String
  targetType String?
  targetId   Int?
  meta       Json?
  createdAt  DateTime @default(now())
}

model AdminSetting {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ShopPlanOverride {
  id           Int       @id @default(autoincrement())
  shopDomain   String    @unique
  overridePlan String
  expiresAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model SubscriptionPlan {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  title       String
  price       Decimal  @db.Decimal(10, 2)
  currency    String   @default("USD")
  interval    String   @default("EVERY_30_DAYS")
  description String?  @db.Text
  features    Json?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SuperAdmin {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String   @db.Text
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
